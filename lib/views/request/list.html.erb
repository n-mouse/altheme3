<%= render partial: 'tabs' %>

<div id="header_left" class="header_left">
  <h1><%= @title %></h1>
  <% if @category %>
    <%= render partial: 'category' %>
    <details class="collapsable-list-filter">
      <summary><%= _("Filter these requests by keyword, date, or status") %></summary>
      <%= render :partial => 'request/request_search_form',
                 :locals => { :after_form_fields => render(
                 :partial => 'request/request_filter_form') } %>
    </details>
  <% else %>
    <%= render :partial => 'request/request_search_form',
               :locals => { :after_form_fields => render(:partial => 'request/request_filter_form') } %>
  <% end %>
</div>


<div style="clear:both"></div>

<div class="results_section">
  <% cache_if_caching_fragments(request_list_cache_key, :expires_in => 5.minutes) do %>
    <%= render :partial => 'list_results' %>
  <% end %>
</div>
